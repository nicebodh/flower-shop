<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboot.mapper.CollectMapper">
        <!--新增-->
    <insert id="insert">
        insert into collect(user_id, goods_id)
        values (#{userId}, #{goodsId})
    </insert>
      <!--删除-->
    <delete id="deleteById">
        delete from collect where id = #{id}
    </delete>
     <!--修改-->
    <update id="update" parameterType="com.example.springboot.entity.Collect">
        update collect
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="goodsId != null">
                goods_id = #{goodsId},
            </if>
        </set>
        where id = #{id}
    </update>
    <!--查询-->
    <select id="selectAll" resultType="com.example.springboot.entity.Collect">
        select collect.*,goods.name as goodsName,goods.status as status,goods.pic as pic,shopkeeper.shop_name as shopName
        from collect
        left join  goods on goods.id=collect.goods_id
        left join  shopkeeper on shopkeeper.id=goods.shopkeeper_id
        <where>
            <if test="userId != null">
                and user_id = #{userId}
            </if>
            <if test="goodsId != null">
                and goods_id = #{goodsId}
            </if>
        </where>
    </select>



</mapper>

